# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_FIRESTORE_DATABASE_ID=(default)

# JWT Configuration
JWT_SECRET=your-jwt-secret-key

# Admin API
ADMIN_SECRET=iamadmin

# Base URL used in generated reset links (no trailing slash)
APP_BASE_URL=https://yourapp.com

# To access firestore from localhost
GOOGLE_APPLICATION_CREDENTIALS=path-to-json-key

APP_ENV=development